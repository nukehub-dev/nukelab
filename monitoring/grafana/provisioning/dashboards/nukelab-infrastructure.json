{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false},
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}"
        }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false},
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=~\"api|celery|worker\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "Backend Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "Active connections"
        },
        {
          "expr": "pg_settings_max_connections - pg_stat_activity_count",
          "legendFormat": "Available connections"
        }
      ],
      "title": "PostgreSQL Connections",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit[1m]) + rate(pg_stat_database_xact_rollback[1m])",
          "legendFormat": "Transactions/sec"
        }
      ],
      "title": "PostgreSQL Transactions",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 5,
      "targets": [
        {
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes",
          "legendFormat": "Memory usage"
        }
      ],
      "title": "Redis Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 6,
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Clients"
        }
      ],
      "title": "Redis Connected Clients",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "id": 7,
      "targets": [
        {
          "expr": "nukelab_registered_users_total",
          "legendFormat": "Users"
        },
        {
          "expr": "nukelab_active_servers_total",
          "legendFormat": "Servers"
        },
        {
          "expr": "nukelab_nuke_instances_total",
          "legendFormat": "Nukes"
        }
      ],
      "title": "Business Metrics",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "id": 8,
      "targets": [
        {
          "expr": "sum by (queue) (celery_task_received_total) / sum by (queue) (celery_task_sent_total)",
          "legendFormat": "{{queue}}"
        }
      ],
      "title": "Celery Task Processing Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["nukelab", "infrastructure"],
