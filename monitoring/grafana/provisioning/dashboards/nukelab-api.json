{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(nukelab_http_requests_total[1m]))",
          "legendFormat": "Total RPS"
        }
      ],
      "title": "Requests Per Second",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(nukelab_http_requests_total{status_code=~\"4..|5..\"}[1m])) / sum(rate(nukelab_http_requests_total[1m]))",
          "legendFormat": "Error Rate"
        }
      ],
      "title": "HTTP Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(nukelab_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(nukelab_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(nukelab_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "title": "API Latency Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(nukelab_http_requests_total[1m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ],
      "title": "Requests by Status Code",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 5,
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum(rate(nukelab_http_request_duration_seconds_bucket[5m])) by (path, le)))",
          "legendFormat": "{{path}}"
        }
      ],
      "title": "Top 10 Slowest Endpoints (p95)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "id": 6,
      "targets": [
        {
          "expr": "nukelab_active_websocket_connections",
          "legendFormat": "Active Connections"
        }
      ],
      "title": "Active WebSocket Connections",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 1, "pointSize": 5, "spanNulls": false},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "id": 7,
      "targets": [
        {
          "expr": "rate(nukelab_redis_cache_hits_total[1m]) / (rate(nukelab_redis_cache_hits_total[1m]) + rate(nukelab_redis_cache_misses_total[1m]))",
          "legendFormat": "Hit Ratio"
        }
      ],
      "title": "Redis Cache Hit Ratio",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["nukelab", "api"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
