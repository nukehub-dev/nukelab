{
  "ignores": [
    "node_modules/**",
    "backend/.venv-dev/**",
    "backend/.venv/**",
    "frontend/node_modules/**",
    "frontend/test-results/**",
    "frontend/dist/**"
  ],
  "config": {
    "default": true,
    "MD013": false,
    "MD024": {
      "siblings_only": true
    },
    "MD033": false,
    "MD040": false,
    "MD041": false,
    "MD046": false,
    "MD060": false
  }
}
